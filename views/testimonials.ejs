<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
        <!-- SEO Tags -->
    <title>About Triloki Divine Journey | Premium Char Dham Operators</title>
    <link rel="icon" type="image/png" href="/assets/logo.png">
    <meta name="description" content="Learn about Triloki Divine Journey, the premium boutique operators for Kedarnath Helicopter and Char Dham Yatra in Uttarakhand. Led by devotion, managed with care.">
    <meta name="keywords" content="Char Dham Yatra 2026, Kedarnath Helicopter Booking, Premium Helicopter Tours Uttarakhand, Do Dham Package, Badrinath VIP Darshan, Triloki Divine Journey">
    <meta name="author" content="Triloki Divine Journey">
    <link rel="canonical" href="https://trilokidivinejourney.com/">
    
    <!-- Open Graph for Social Sharing -->
    <meta property="og:title" content="About Triloki Divine Journey | Premium Char Dham Operators">
    <meta property="og:description" content="Learn about Triloki Divine Journey, the premium boutique operators for Kedarnath Helicopter and Char Dham Yatra in Uttarakhand. Led by devotion, managed with care.">
    <meta property="og:image" content="https://trilokidivinejourney.com/assets/logo.png">
    <meta property="og:url" content="https://trilokidivinejourney.com/">
    <meta property="og:type" content="website">

    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="style.css">
    <link rel="stylesheet" href="premium.css">

    <!-- JSON-LD Schema Markup -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "TravelAgency",
      "name": "Triloki Divine Journey",
      "image": "https://trilokidivinejourney.com/assets/logo.png",
      "@id": "https://trilokidivinejourney.com",
      "url": "https://trilokidivinejourney.com",
      "telephone": "<%= settings.phone %>",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Dehradun, Uttarakhand",
        "addressRegion": "UK",
        "addressCountry": "IN"
      },
      "description": "Learn about Triloki Divine Journey, the premium boutique operators for Kedarnath Helicopter and Char Dham Yatra in Uttarakhand. Led by devotion, managed with care.",
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "reviewCount": "342"
      }
    }
    </script>
</head>
<body>
    <main>
    <!-- Modern Two-Tier Navbar -->
    <header class="top-nav-container">
        <div class="nav-top">
            <a href="/" class="logo">
                <img src="assets/logo.png" alt="Triloki Divine Journey">
            </a>
            
            <div class="nav-announcement">
                <span class="pulse-dot"></span>
                <span class="announcement-text">Bookings Open for Char Dham Yatra 2026</span>
                <a href="#" onclick="document.getElementById('inquiryModal').style.display='flex'" class="announcement-link">Book Now <i class="fa-solid fa-arrow-right"></i></a>
            </div>

            <div class="nav-actions">
                <a href="https://www.instagram.com/trilokigroup/" target="_blank" class="social-icon"><i class="fa-brands fa-instagram"></i> <span>2.2k</span></a>
                <button class="mobile-menu-btn" id="mobileMenuBtn">
                    <i class="fa-solid fa-bars"></i>
                </button>
            </div>
        </div>

        <!-- Sub Navbar with Emojis -->
        <div class="nav-bottom border-bottom">
            <div class="nav-bottom-scroll container">
                <a href="#premium-heli-packages" class="emoji-link">🚁 Heli Tours</a>
                <a href="#mixed-journeys" class="emoji-link">🚍 Road Tours</a>
                <a href="/chardham" class="emoji-link">🏔️ Char Dham</a>
                <a href="/testimonials" class="emoji-link">🤝 Testimonials</a>
                <a href="/about" class="emoji-link">📌 About Us</a>
            </div>
        </div>

    </header>

    <div class="mobile-menu" id="mobileMenu">
        <a href="#premium-heli-packages">Heli Tours</a>
        <a href="/#mixed-journeys">Road Tours</a>
        <a href="/testimonials">Testimonials</a>
        <a href="#contact">Contact</a>
    </div>

    
    <!-- Testimonials Hero -->
    <div class="about-massive-hero" style="background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.7)), url('https://placehold.co/1920x1080/1a237e/FFFFFF?text=Pilgrims+Yatra'); background-size: cover; background-position: center; min-height: 40vh; display: flex; align-items: center; justify-content: center; text-align: center; color: white;">
        <div class="container" style="padding: 100px 20px;">
            <h1 style="font-size: 4rem; margin-bottom: 25px; font-weight: 700; text-shadow: 2px 4px 10px rgba(0,0,0,0.5);">Yatri Testimonials</h1>
            <p style="font-size: 1.4rem; max-width: 900px; margin: 0 auto; line-height: 1.8; text-shadow: 1px 2px 5px rgba(0,0,0,0.5);">Read and watch the divine experiences of our valued yatris.</p>
        </div>
    </div>

    <!-- Testimonials Grid Section -->
    <section class="testimonials-page-section" style="background: white; padding: 80px 0;">
        <div class="container" style="max-width: 1200px; margin: 0 auto;">
            
            <div style="display: flex; justify-content: center; margin-bottom: 60px;">
                <div class="google-review-badge">
                    <div class="g-icon-wrapper">
                        <i class="fa-brands fa-google"></i>
                    </div>
                    <div class="g-content-horizontal">
                        <div class="g-stars-row">
                            <span class="g-score">4.9</span>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                        </div>
                        <span class="g-text-row">Based on <strong>300+</strong> reviews</span>
                    </div>
                </div>
            </div>

            <div class="testimonials-grid" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px;">
                <% if(typeof reviews !== 'undefined') { %>
                    <% reviews.videos.forEach((vid, index) => { %>
                    <div class="review-card video-card" style="width: 100%; border-radius: 20px; overflow: hidden; position: relative; box-shadow: 0 10px 20px rgba(0,0,0,0.1);">
                        <video class="review-video" src="/assets/<%= vid %>" controls style="width: 100%; height: 100%; object-fit: cover; aspect-ratio: 9/16;"></video>
                    </div>
                    <% }) %>
                    
                    <% reviews.images.forEach((img, index) => { %>
                    <div class="review-card image-card" style="width: 100%; border-radius: 20px; overflow: hidden; box-shadow: 0 10px 20px rgba(0,0,0,0.1);">
                        <img src="/assets/<%= img %>" alt="Testimonial <%= index + 1 %>" loading="lazy" style="width: 100%; height: 100%; object-fit: cover; aspect-ratio: 9/16;">
                    </div>
                    <% }) %>
                <% } else { %>
                    <p style="grid-column: 1 / -1; text-align: center;">No testimonials available yet.</p>
                <% } %>
            </div>
            
            <!-- Mobile Responsive Fix for Grid -->
            <style>
                @media (max-width: 768px) {
                    .testimonials-grid {
                        grid-template-columns: repeat(1, 1fr) !important;
                        padding: 0 20px;
                    }
                }
            </style>

        </div>
    </section>
    </section>
<footer id="contact" class="footer">
        <div class="footer-grid">
            <div class="footer-brand">
                <a href="#home" class="logo">
                    <img src="assets/logo.png" alt="Triloki Tours & Travels Logo">
                </a>
                <p>Your trusted partner for premium spiritual journeys and luxury pilgrimage experiences across India.</p>
                <div class="social-links">
                    <a href="#"><i class="fa-brands fa-facebook-f"></i></a>
                    <a href="#"><i class="fa-brands fa-instagram"></i></a>
                    <a href="#"><i class="fa-brands fa-x-twitter"></i></a>
                    <a href="#"><i class="fa-brands fa-youtube"></i></a>
                </div>
            </div>
            <div class="footer-links">
                <h3>Quick Links</h3>
                <ul>
                    <li><a href="#home">Home</a></li>
                    <li><a href="#packages">Char Dham Packages</a></li>
                    <li><a href="#heli">Heli Tours</a></li>
                    <li><a href="/about">About Us</a></li>
                </ul>
            </div>
            <div class="footer-contact">
                <h3>Contact Information</h3>
                <ul>
                    <li><i class="fa-solid fa-phone"></i> <%= settings.phone %> | +91 9193336211</li>
                    <li><i class="fa-solid fa-envelope"></i> <%= settings.email %></li>
                    <li><i class="fa-solid fa-location-dot"></i> <%= settings.location %></li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            <p class="disclaimer">Disclaimer: We are tour integrators. Helicopter services are subject to weather conditions and DGCA guidelines.</p>
            <p>&copy; 2026 Triloki hospitality. All rights reserved.</p>
        </div>
    </footer>

    <!-- Inquiry Modal -->
    <div class="modal" id="inquiryModal">
        <div class="modal-content">
            <span class="close-modal" onclick="closeModal()">&times;</span>
            <h2>Request a Quote</h2>
            <p>Fill out your details and our spiritual journey expert will contact you shortly.</p>
            <form class="inquiry-form" onsubmit="event.preventDefault(); closeModal(); alert('Thank you! We will contact you soon.');">
                <input type="text" placeholder="Full Name" required>
                <input type="tel" placeholder="Phone Number" required>
                <input type="email" placeholder="Email Address">
                <select>
                    <option value="">Select Package</option>
                    <option value="dodham">Do Dham Yatra (Heli)</option>
                    <option value="chardham-road">Char Dham Premium (Road)</option>
                    <option value="chardham-heli">Complete Char Dham (Heli)</option>
                    <option value="ekdham">Ek Dham Yatra (Road)</option>
                </select>
                <button type="submit" class="cta-btn primary-btn submit-btn">Submit Request</button>
            </form>
        </div>
    </div>

    </main>
    <script src="script.js"></script>
</body>
</html>
