    <style>
        .charter-hero {
            position: relative;
            height: 50vh;
            min-height: 400px;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            color: white;
            background: linear-gradient(rgba(10, 10, 10, 0.7), rgba(10, 10, 10, 0.9)), url('/assets/chardham_1.jpg') center/cover;
            padding: 20px;
            margin-bottom: 50px;
            border-bottom: 2px solid #d4af37;
        }

        .charter-hero h1 {
            font-size: 3.5rem;
            margin-bottom: 15px;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: #d4af37;
        }

        .charter-hero p {
            font-size: 1.2rem;
            max-width: 600px;
            margin: 0 auto 30px;
            opacity: 0.9;
        }

        .whatsapp-btn-large {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            background: #25D366;
            color: white !important;
            padding: 12px 25px;
            border-radius: 30px;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s ease;
            width: 100%;
            border: none;
            cursor: pointer;
        }

        .whatsapp-btn-large:hover {
            background: #128C7E;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(37, 211, 102, 0.3);
        }

        .charter-footer-override {
            border-top: 1px solid rgba(255,255,255,0.05);
            padding-top: 20px;
            margin-top: 20px;
        }

        .why-choose-charter {
            background: #0a0a0a;
            padding: 50px 20px;
            border-top: 1px solid #222;
            border-bottom: 1px solid #222;
            margin-bottom: 50px;
            text-align: center;
        }

        .features-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            max-width: 1000px;
            margin: 40px auto 0;
        }

        .feature-box i {
            font-size: 2.5rem;
            color: #d4af37;
            margin-bottom: 15px;
        }
        
        @media (max-width: 768px) {
            .charter-hero h1 { font-size: 2.5rem; }
        }
    </style>
</head>
