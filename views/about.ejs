<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
        <!-- SEO Tags -->
    <title>About Triloki Divine Journey | Premium Char Dham Operators</title>
    <link rel="icon" type="image/png" href="/assets/logo.png">
    <meta name="description" content="Learn about Triloki Divine Journey, the premium boutique operators for Kedarnath Helicopter and Char Dham Yatra in Uttarakhand. Led by devotion, managed with care.">
    <meta name="keywords" content="Char Dham Yatra 2026, Kedarnath Helicopter Booking, Premium Helicopter Tours Uttarakhand, Do Dham Package, Badrinath VIP Darshan, Triloki Divine Journey">
    <meta name="author" content="Triloki Divine Journey">
    <link rel="canonical" href="https://trilokigroup.in/">
    
    <!-- Open Graph for Social Sharing -->
    <meta property="og:title" content="About Triloki Divine Journey | Premium Char Dham Operators">
    <meta property="og:description" content="Learn about Triloki Divine Journey, the premium boutique operators for Kedarnath Helicopter and Char Dham Yatra in Uttarakhand. Led by devotion, managed with care.">
    <meta property="og:image" content="https://trilokigroup.in/assets/logo.png">
    <meta property="og:url" content="https://trilokigroup.in/">
    <meta property="og:type" content="website">

    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
    <link rel="stylesheet" href="style.css">
    <link rel="stylesheet" href="premium.css">

    <!-- JSON-LD Schema Markup -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "TravelAgency",
      "name": "Triloki Divine Journey",
      "image": "https://trilokigroup.in/assets/logo.png",
      "@id": "https://trilokigroup.in",
      "url": "https://trilokigroup.in",
      "telephone": "<%= settings.phone %>",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Dehradun, Uttarakhand",
        "addressRegion": "UK",
        "addressCountry": "IN"
      },
      "description": "Learn about Triloki Divine Journey, the premium boutique operators for Kedarnath Helicopter and Char Dham Yatra in Uttarakhand. Led by devotion, managed with care.",
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "reviewCount": "342"
      }
    }
    </script>
</head>
<body>
    <main>
    <!-- Modern Two-Tier Navbar -->
    <header class="top-nav-container">
        <div class="nav-top">
            <a href="/" class="logo">
                <img src="assets/logo.png" alt="Triloki Divine Journey">
            </a>
            
            <div class="nav-announcement">
                <span class="pulse-dot"></span>
                <span class="announcement-text">Bookings Open for Char Dham Yatra 2026</span>
                <a href="#" onclick="openModal()" class="announcement-link">Book Now <i class="fa-solid fa-arrow-right"></i></a>
            </div>

            <div class="nav-actions">
                <a href="https://www.instagram.com/trilokigroup/" target="_blank" class="social-icon" style="width: 38px; height: 38px; padding: 0; justify-content: center;"><i class="fa-brands fa-instagram"></i></a> <a href="https://www.facebook.com/61575505050183/about/" target="_blank" class="social-icon" style="margin-left: 10px; width: 38px; height: 38px; padding: 0; justify-content: center;"><i class="fa-brands fa-facebook"></i></a> <a href="https://wa.me/918445214371" target="_blank" class="social-icon" style="margin-left: 10px; width: 38px; height: 38px; padding: 0; justify-content: center;"><i class="fa-brands fa-whatsapp"></i></a>
                
            </div>
        </div>

        <!-- Sub Navbar with Emojis -->
        <div class="nav-bottom border-bottom">
            <div class="nav-bottom-scroll container">
                <a href="/#premium-heli-packages" class="emoji-link">🚁 Heli Tours</a>
                <a href="/#mixed-journeys" class="emoji-link">🚍 Road Tours</a>
                <a href="/chardham" class="emoji-link">🏔️ Char Dham</a>
                <a href="/testimonials" class="emoji-link">🤝 Testimonials</a>
                <a href="/about" class="emoji-link">📌 About Us</a>
            </div>
        </div>

    </header>

    <div class="mobile-menu" id="mobileMenu">
        <a href="/#premium-heli-packages">Heli Tours</a>
        <a href="/#mixed-journeys">Road Tours</a>
        <a href="/testimonials">Testimonials</a>
        <a href="#contact">Contact</a>
    </div>

    
    <!-- Page Header -->
    <div style="background: var(--secondary); padding: 180px 20px 80px; text-align: center; color: white;">
        <div class="container" style="max-width: 800px; margin: 0 auto;">
            <h1 style="font-size: 3.5rem; margin-bottom: 20px; font-weight: 700;">Our Story</h1>
            <p style="font-size: 1.2rem; line-height: 1.8; color: rgba(255,255,255,0.8);">A deeply personal commitment to crafting the most divine and seamless spiritual journeys across Uttarakhand.</p>
        </div>
    </div>

    <!-- About Section -->
    <section class="premium-packages-section" style="background: white; padding: 80px 0;">
        <div class="container" style="max-width: 1000px; margin: 0 auto;">
            <div class="section-header">
                <h2>Led by Devotion, Managed with Care</h2>
                <div class="divider"></div>
            </div>
            
            <div class="about-hero-grid">
                <div>
                    <img src="/assets/new/kedarnath.jpeg" alt="Our Founders" style="width: 100%; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.1);">
                </div>
                <div>
                    <h3 style="font-size: 1.8rem; color: var(--text-main); margin-bottom: 20px;">A Boutique Pilgrimage Experience</h3>
                    <p style="color: var(--text-muted); line-height: 1.8; margin-bottom: 15px; font-size: 1.05rem;">At Triloki Divine Journey, we believe that a pilgrimage is an intimate spiritual calling, not just a travel itinerary. That is why our agency is distinctly different—it is entirely led and managed by our founders.</p>
                    <p style="color: var(--text-muted); line-height: 1.8; font-size: 1.05rem;">We do not rely on a massive corporate chain of command. From your very first inquiry to the moment you return home with the blessings of the Almighty, you are interacting directly with the visionaries of our agency. We personally oversee every helicopter booking, every VIP darshan, and every road transport to ensure your journey is flawless.</p>
                </div>
            </div>

            <div style="text-align: center; margin-top: 80px;">
                <h3 style="font-size: 1.8rem; color: var(--text-main); margin-bottom: 30px;">Our Philosophy</h3>
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px;">
                    <div style="padding: 40px; background: var(--bg-light); border-radius: 20px; border: 1px solid var(--border);">
                        <i class="fa-solid fa-hand-holding-heart" style="font-size: 3rem; color: var(--primary); margin-bottom: 20px;"></i>
                        <h4 style="font-size: 1.3rem; margin-bottom: 15px;">Personalized Attention</h4>
                        <p style="color: var(--text-muted); line-height: 1.6;">Because we manage everything directly, we guarantee a level of personal care and rapid response that large agencies simply cannot match.</p>
                    </div>
                    <div style="padding: 40px; background: var(--bg-light); border-radius: 20px; border: 1px solid var(--border);">
                        <i class="fa-solid fa-crown" style="font-size: 3rem; color: var(--gold); margin-bottom: 20px;"></i>
                        <h4 style="font-size: 1.3rem; margin-bottom: 15px;">Premium Standards</h4>
                        <p style="color: var(--text-muted); line-height: 1.6;">We have personally vetted every helicopter service, hotel, and guide to ensure your spiritual journey meets our strict luxury standards.</p>
                    </div>
                    <!-- New Philosophy Cards -->
                    <div style="padding: 40px; background: var(--bg-light); border-radius: 20px; border: 1px solid var(--border);">
                        <i class="fa-solid fa-shield-halved" style="font-size: 3rem; color: #2ecc71; margin-bottom: 20px;"></i>
                        <h4 style="font-size: 1.3rem; margin-bottom: 15px;">Absolute Safety</h4>
                        <p style="color: var(--text-muted); line-height: 1.6;">Your well-being is our priority. We partner strictly with DGCA-approved helicopter operators and adhere to all weather protocols for a risk-free Yatra.</p>
                    </div>
                    <div style="padding: 40px; background: var(--bg-light); border-radius: 20px; border: 1px solid var(--border);">
                        <i class="fa-solid fa-om" style="font-size: 3rem; color: #e67e22; margin-bottom: 20px;"></i>
                        <h4 style="font-size: 1.3rem; margin-bottom: 15px;">Spiritual Authenticity</h4>
                        <p style="color: var(--text-muted); line-height: 1.6;">We ensure the true essence of your pilgrimage is maintained, offering VIP Darshan passes and arranging authentic pujas with verified temple Pandits.</p>
                    </div>
                </div>
            </div>

            <!-- Our Journey Timeline -->
            <div style="margin-top: 100px;">
                <div class="section-header">
                    <h2>Our Journey of Devotion</h2>
                    <div class="divider"></div>
                </div>
                <div style="max-width: 800px; margin: 40px auto; border-left: 4px solid var(--primary); padding-left: 30px; display: flex; flex-direction: column; gap: 40px;">
                    <div style="position: relative;">
                        <span style="position: absolute; left: -43px; top: 0; background: white; color: var(--primary); width: 20px; height: 20px; border-radius: 50%; border: 4px solid var(--primary);"></span>
                        <h4 style="color: var(--primary); font-size: 1.2rem; margin-bottom: 10px;">The Beginning</h4>
                        <p style="color: var(--text-muted); line-height: 1.6;">Triloki Divine Journey was born out of a profound personal spiritual awakening in the Himalayas, with a mission to make the divine accessible to all.</p>
                    </div>
                    <div style="position: relative;">
                        <span style="position: absolute; left: -43px; top: 0; background: white; color: var(--primary); width: 20px; height: 20px; border-radius: 50%; border: 4px solid var(--primary);"></span>
                        <h4 style="color: var(--primary); font-size: 1.2rem; margin-bottom: 10px;">Partnering for Premium</h4>
                        <p style="color: var(--text-muted); line-height: 1.6;">We established exclusive partnerships with top-tier DGCA-approved helicopter operators and luxury accommodations across the Char Dham circuit.</p>
                    </div>
                    <div style="position: relative;">
                        <span style="position: absolute; left: -43px; top: 0; background: white; color: var(--primary); width: 20px; height: 20px; border-radius: 50%; border: 4px solid var(--primary);"></span>
                        <h4 style="color: var(--primary); font-size: 1.2rem; margin-bottom: 10px;">Thousands of Blessings</h4>
                        <p style="color: var(--text-muted); line-height: 1.6;">Today, we have proudly facilitated seamless, VIP spiritual journeys for thousands of satisfied pilgrims from across the globe.</p>
                    </div>
                </div>
            </div>

            <!-- Behind the Scenes Video -->
            <div style="margin-top: 100px; text-align: center;">
                <div class="section-header">
                    <h2>See Us in Action</h2>
                    <div class="divider"></div>
                    <p class="about-subtitle">A glimpse into how we personally manage your divine journey.</p>
                </div>
                <div style="margin-top: 40px; position: relative; max-width: 900px; margin-left: auto; margin-right: auto; border-radius: 20px; overflow: hidden; box-shadow: 0 15px 40px rgba(0,0,0,0.15);">
                    <img src="/assets/hero.png" alt="Behind the scenes video" style="width: 100%; display: block;">
                    <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: rgba(230, 57, 70, 0.9); color: white; width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2rem; cursor: pointer; box-shadow: 0 0 0 10px rgba(230, 57, 70, 0.3);">
                        <i class="fa-solid fa-play" style="margin-left: 5px;"></i>
                    </div>
                </div>
            </div>

            <!-- Meet the Ground Team -->
            <div style="margin-top: 100px; text-align: center;">
                <div class="section-header">
                    <h2>Our Local Experts</h2>
                    <div class="divider"></div>
                    <p class="about-subtitle">The dedicated hands on the ground making your Yatra seamless.</p>
                </div>
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 40px; margin-top: 40px;">
                    <div style="text-align: center;">
                        <div style="width: 120px; height: 120px; border-radius: 50%; background: #fff4e6; margin: 0 auto 20px auto; border: 4px solid white; box-shadow: 0 10px 20px rgba(0,0,0,0.1); display: flex; align-items: center; justify-content: center; font-size: 3rem; color: var(--primary);">
                            <i class="fa-solid fa-map-location-dot"></i>
                        </div>
                        <h4 style="font-size: 1.3rem; margin-bottom: 5px;">Expert Guides</h4>
                        <p style="color: var(--text-muted); font-size: 0.95rem;">Navigating the terrains</p>
                    </div>
                    <div style="text-align: center;">
                        <div style="width: 120px; height: 120px; border-radius: 50%; background: #e8f5e9; margin: 0 auto 20px auto; border: 4px solid white; box-shadow: 0 10px 20px rgba(0,0,0,0.1); display: flex; align-items: center; justify-content: center; font-size: 3rem; color: #2e7d32;">
                            <i class="fa-solid fa-om"></i>
                        </div>
                        <h4 style="font-size: 1.3rem; margin-bottom: 5px;">Verified Pandits</h4>
                        <p style="color: var(--text-muted); font-size: 0.95rem;">Performing authentic pujas</p>
                    </div>
                    <div style="text-align: center;">
                        <div style="width: 120px; height: 120px; border-radius: 50%; background: #e3f2fd; margin: 0 auto 20px auto; border: 4px solid white; box-shadow: 0 10px 20px rgba(0,0,0,0.1); display: flex; align-items: center; justify-content: center; font-size: 3rem; color: #1565c0;">
                            <i class="fa-solid fa-helicopter"></i>
                        </div>
                        <h4 style="font-size: 1.3rem; margin-bottom: 5px;">Veteran Pilots</h4>
                        <p style="color: var(--text-muted); font-size: 0.95rem;">Ensuring absolute safety</p>
                    </div>
                </div>
            </div>
            
            <!-- Final CTA -->
            <div style="margin-top: 100px; background: linear-gradient(135deg, var(--secondary), #1a1a2e); border-radius: 30px; padding: 60px 40px; text-align: center; color: white; box-shadow: 0 20px 50px rgba(0,0,0,0.2);">
                <h2 style="font-size: 2.5rem; margin-bottom: 20px; color: white;">Ready for the Journey of a Lifetime?</h2>
                <p style="font-size: 1.2rem; max-width: 600px; margin: 0 auto 40px; color: rgba(255,255,255,0.8);">Let our founders personally craft and manage your flawless spiritual experience in Uttarakhand.</p>
                
                <form class="inquiry-form" onsubmit="handleInquirySubmit(event)" style="background: white; padding: 40px; border-radius: 20px; max-width: 800px; margin: 0 auto; display: flex; flex-direction: column; gap: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.1);">
                    <div class="form-two-cols">
                        <input type="text" name="name" placeholder="Full Name" required style="width: 100%; padding: 15px; border: 1px solid #ddd; border-radius: 10px; font-size: 1rem;">
                        <input type="tel" name="phone" placeholder="Phone Number" required style="width: 100%; padding: 15px; border: 1px solid #ddd; border-radius: 10px; font-size: 1rem;">
                    </div>
                    <input type="email" name="email" placeholder="Email Address" style="width: 100%; padding: 15px; border: 1px solid #ddd; border-radius: 10px; font-size: 1rem;">
                    <select style="width: 100%; padding: 15px; border: 1px solid #ddd; border-radius: 10px; font-size: 1rem; color: #333; background: white;">
                        <option value="">Select Package</option>
                        <option value="dodham">Do Dham Yatra (Heli)</option>
                        <option value="chardham-road">Char Dham Premium (Road)</option>
                        <option value="chardham-heli">Complete Char Dham (Heli)</option>
                        <option value="ekdham">Ek Dham Yatra (Road)</option>
                    </select>
                    <button type="submit" class="cta-btn primary-btn" style="width: 100%; padding: 15px; border: none; border-radius: 10px; font-size: 1.2rem; cursor: pointer; margin-top: 10px;">Submit Your Details</button>
                </form>
            </div>

        </div>
    </section>
<footer id="contact" class="footer">
        <div class="footer-grid">
            <div class="footer-brand">
                <a href="/" class="logo">
                    <img src="assets/logo.png" alt="Triloki Tours & Travels Logo">
                </a>
                <p>Your trusted partner for premium spiritual journeys and luxury pilgrimage experiences across India.</p>
                <div class="social-links">
                    <a href="#"><i class="fa-brands fa-facebook-f"></i></a>
                    <a href="https://www.instagram.com/trilokigroup/"><i class="fa-brands fa-instagram"></i></a> <a href="https://www.facebook.com/61575505050183/about/" target="_blank"><i class="fa-brands fa-facebook"></i></a> <a href="https://wa.me/918445214371" target="_blank"><i class="fa-brands fa-whatsapp"></i></a>
                    <a href="#"><i class="fa-brands fa-x-twitter"></i></a>
                    <a href="#"><i class="fa-brands fa-youtube"></i></a>
                </div>
            </div>
            <div class="footer-links">
                <h3>Quick Links</h3>
                <ul>
                    <li><a href="/">Home</a></li>
                    <li><a href="/#mixed-journeys">Char Dham Packages</a></li>
                    <li><a href="/#premium-heli-packages">Heli Tours</a></li>
                    <li><a href="/about">About Us</a></li>
                </ul>
            </div>
            <div class="footer-contact">
                <h3>Contact Information</h3>
                <ul>
                    <li><i class="fa-solid fa-phone"></i> <%= settings.phone %> | +91 9193336211</li>
                    <li><i class="fa-solid fa-envelope"></i> <%= settings.email %></li>
                    <li><i class="fa-solid fa-location-dot"></i> <%= settings.location %></li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            <p class="disclaimer">Disclaimer: We are tour integrators. Helicopter services are subject to weather conditions and DGCA guidelines.</p>
            <p>&copy; 2026 Triloki hospitality. All rights reserved.</p>
        </div>
    </footer>

    <!-- Inquiry Modal -->
    <div class="modal" id="inquiryModal">
        <div class="modal-content">
            <span class="close-modal" onclick="closeModal()">&times;</span>
            <h2>Request a Quote</h2>
            <p>Fill out your details and our spiritual journey expert will contact you shortly.</p>
            <form class="inquiry-form" onsubmit="handleInquirySubmit(event)" >
                <input type="text" name="name" placeholder="Full Name" required>
                <input type="tel" name="phone" placeholder="Phone Number" required>
                <input type="email" name="email" placeholder="Email Address">
                <select name="package">
                    <option value="">Select Package</option>
                    <% if (typeof packages !== 'undefined' && packages) { packages.forEach(pkg => { %>
                        <option value="<%= pkg.title %>"><%= pkg.title %></option>
                    <% }); } %>
                </select>
                <button type="submit" class="cta-btn primary-btn submit-btn">Submit Request</button>
            </form>
        </div>
    </div>

    </main>
    <script src="script.js?v=2"></script>
</body>
</html>


