      "@context": "https://schema.org",
      "@type": "TravelAgency",
      "name": "Triloki Divine Journey",
      "image": "https://trilokidivinejourney.com/assets/logo.png",
      "@id": "https://trilokidivinejourney.com",
      "url": "https://trilokidivinejourney.com",
      "telephone": "<%= settings.phone %>",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Dehradun, Uttarakhand",
        "addressRegion": "UK",
        "addressCountry": "IN"
      },
      "description": "Learn about Triloki Divine Journey, the premium boutique operators for Kedarnath Helicopter and Char Dham Yatra in Uttarakhand. Led by devotion, managed with care.",
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "reviewCount": "342"
      }
    }
    </script>
</head>
<body>
    <main>
    <!-- Modern Two-Tier Navbar -->
    <header class="top-nav-container">
        <div class="nav-top">
            <a href="/" class="logo">
                <img src="assets/logo.png" alt="Triloki Divine Journey">
            </a>
            
            <div class="nav-announcement">
                <span class="pulse-dot"></span>
                <span class="announcement-text">Bookings Open for Char Dham Yatra 2026</span>
                <a href="#" onclick="openModal()" class="announcement-link">Book Now <i class="fa-solid fa-arrow-right"></i></a>
            </div>

            <div class="nav-actions">
                <a href="https://www.instagram.com/trilokigroup/" target="_blank" class="social-icon"><i class="fa-brands fa-instagram"></i> <span>2.2k</span></a>
                <button class="mobile-menu-btn" id="mobileMenuBtn">
                    <i class="fa-solid fa-bars"></i>
                </button>
            </div>
        </div>

        <!-- Sub Navbar with Emojis -->
        <div class="nav-bottom border-bottom">
            <div class="nav-bottom-scroll container">
                <a href="/#premium-heli-packages" class="emoji-link">🚁 Heli Tours</a>
                <a href="/#mixed-journeys" class="emoji-link">🚍 Road Tours</a>
                <a href="/chardham" class="emoji-link">🏔️ Char Dham</a>
                <a href="/testimonials" class="emoji-link">🤝 Testimonials</a>
                <a href="/about" class="emoji-link">📌 About Us</a>
            </div>
        </div>

    </header>

    <div class="mobile-menu" id="mobileMenu">
        <a href="/#premium-heli-packages">Heli Tours</a>
        <a href="/#mixed-journeys">Road Tours</a>
        <a href="/testimonials">Testimonials</a>
        <a href="#contact">Contact</a>
    </div>

    
    <!-- Page Header -->
    <div style="background: var(--secondary); padding: 180px 20px 80px; text-align: center; color: white;">
        <div class="container" style="max-width: 800px; margin: 0 auto;">
            <h1 style="font-size: 3.5rem; margin-bottom: 20px; font-weight: 700; color: var(--gold);">The Char Dham Yatra</h1>
            <p style="font-size: 1.2rem; line-height: 1.8; color: rgba(255,255,255,0.8);">Discover the spiritual significance of Uttarakhand's four most sacred shrines in Hindu Dharma.</p>
        </div>
    </div>

    <!-- Temples Details Section -->
    <section class="premium-packages-section" style="background: white; padding: 80px 0;">
        <div class="container" style="max-width: 1100px; margin: 0 auto;">
            
            <!-- Yamunotri -->
            <div style="display: grid; grid-template-columns: 1fr 1.2fr; gap: 50px; align-items: center; margin-bottom: 80px; padding: 30px; background: var(--bg-light); border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.05);">
                <div style="border-radius: 15px; overflow: hidden; box-shadow: 0 15px 30px rgba(0,0,0,0.15);">
                    <img src="/assets/new/yamontri.jpeg" alt="Yamunotri Temple" style="width: 100%; height: 100%; object-fit: cover; display: block;">
                </div>
                <div>
                    <h3 style="font-size: 2.2rem; color: var(--primary); margin-bottom: 15px; display: flex; align-items: center; gap: 15px;">
                        Yamunotri <span style="font-size: 1rem; padding: 5px 15px; background: rgba(230, 57, 70, 0.1); border-radius: 20px; color: var(--primary);">1st Dham</span>
                    </h3>
                    <h4 style="font-size: 1.2rem; color: var(--text-main); margin-bottom: 20px; font-weight: 500;">Seat of Goddess Yamuna</h4>
                    <p style="color: var(--text-muted); line-height: 1.8; margin-bottom: 15px; font-size: 1.05rem;">
                        Yamunotri is the first stop in the Char Dham Yatra. It is the spiritual source of the sacred River Yamuna, the second most holy river in Hinduism. 
                    </p>
                    <p style="color: var(--text-muted); line-height: 1.8; font-size: 1.05rem;">
                        <strong>Spiritual Significance:</strong> According to Hindu mythology, Goddess Yamuna is the daughter of Surya (the Sun God) and the sister of Yama (the God of Death). It is deeply believed that taking a holy dip in the pristine waters of the Yamuna cleanses all mortal sins and protects the devotee from an untimely or painful death.
                    </p>
                </div>
            </div>

            <!-- Gangotri -->
            <div style="display: grid; grid-template-columns: 1fr 1.2fr; gap: 50px; align-items: center; margin-bottom: 80px; padding: 30px; background: var(--bg-light); border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.05);">
                <div style="border-radius: 15px; overflow: hidden; box-shadow: 0 15px 30px rgba(0,0,0,0.15);">
                    <img src="/assets/new/gangotri.jpeg" alt="Gangotri Temple" style="width: 100%; height: 100%; object-fit: cover; display: block;">
                </div>
                <div>
                    <h3 style="font-size: 2.2rem; color: var(--primary); margin-bottom: 15px; display: flex; align-items: center; gap: 15px;">
                        Gangotri <span style="font-size: 1rem; padding: 5px 15px; background: rgba(230, 57, 70, 0.1); border-radius: 20px; color: var(--primary);">2nd Dham</span>
                    </h3>
                    <h4 style="font-size: 1.2rem; color: var(--text-main); margin-bottom: 20px; font-weight: 500;">Seat of Goddess Ganga</h4>
                    <p style="color: var(--text-muted); line-height: 1.8; margin-bottom: 15px; font-size: 1.05rem;">
                        Gangotri marks the spiritual origin of the River Ganges (Ganga), the holiest river in India. The temple stands at the exact spot where Goddess Ganga is said to have touched the earth.
                    </p>
                    <p style="color: var(--text-muted); line-height: 1.8; font-size: 1.05rem;">
                        <strong>Spiritual Significance:</strong> In Hindu Dharma, the Ganga descended from heaven to earth to wash away the sins of King Bhagirath's ancestors. Lord Shiva caught the mighty river in his matted locks to save the earth from her immense force. Visiting Gangotri brings profound spiritual purification, peace to one's ancestors, and liberation (Moksha).
                    </p>
                </div>
            </div>

            <!-- Kedarnath -->
            <div style="display: grid; grid-template-columns: 1fr 1.2fr; gap: 50px; align-items: center; margin-bottom: 80px; padding: 30px; background: var(--bg-light); border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.05);">
                <div style="border-radius: 15px; overflow: hidden; box-shadow: 0 15px 30px rgba(0,0,0,0.15);">
                    <img src="/assets/new/kedarnath.jpeg" alt="Kedarnath Temple" style="width: 100%; height: 100%; object-fit: cover; display: block;">
                </div>
                <div>
                    <h3 style="font-size: 2.2rem; color: var(--primary); margin-bottom: 15px; display: flex; align-items: center; gap: 15px;">
                        Kedarnath <span style="font-size: 1rem; padding: 5px 15px; background: rgba(230, 57, 70, 0.1); border-radius: 20px; color: var(--primary);">3rd Dham</span>
                    </h3>
                    <h4 style="font-size: 1.2rem; color: var(--text-main); margin-bottom: 20px; font-weight: 500;">The Highest Jyotirlinga of Lord Shiva</h4>
                    <p style="color: var(--text-muted); line-height: 1.8; margin-bottom: 15px; font-size: 1.05rem;">
                        Situated at a breathtaking altitude of 3,583 meters near the Mandakini river, Kedarnath is one of the most revered shrines of Lord Shiva and the highest of the 12 Jyotirlingas in India.
                    </p>
                    <p style="color: var(--text-muted); line-height: 1.8; font-size: 1.05rem;">
                        <strong>Spiritual Significance:</strong> Built originally by the Pandavas to seek Lord Shiva's forgiveness for the sins of the Kurukshetra war, Kedarnath is the ultimate destination for Shiva devotees. The journey here is considered a test of devotion, and attaining Darshan of the triangular Shiva lingam is said to grant spiritual salvation and freedom from the cycle of rebirth.
                    </p>
                </div>
            </div>

            <!-- Badrinath -->
            <div style="display: grid; grid-template-columns: 1fr 1.2fr; gap: 50px; align-items: center; margin-bottom: 80px; padding: 30px; background: var(--bg-light); border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.05);">
                <div style="border-radius: 15px; overflow: hidden; box-shadow: 0 15px 30px rgba(0,0,0,0.15);">
                    <img src="/assets/new/badrinath.jpeg" alt="Badrinath Temple" style="width: 100%; height: 100%; object-fit: cover; display: block;">
                </div>
                <div>
                    <h3 style="font-size: 2.2rem; color: var(--primary); margin-bottom: 15px; display: flex; align-items: center; gap: 15px;">
                        Badrinath <span style="font-size: 1rem; padding: 5px 15px; background: rgba(230, 57, 70, 0.1); border-radius: 20px; color: var(--primary);">4th Dham</span>
                    </h3>
                    <h4 style="font-size: 1.2rem; color: var(--text-main); margin-bottom: 20px; font-weight: 500;">Abode of Lord Vishnu</h4>
                    <p style="color: var(--text-muted); line-height: 1.8; margin-bottom: 15px; font-size: 1.05rem;">
                        Badrinath is the final destination of the Char Dham Yatra. It is dedicated to Lord Vishnu and is unique because it is part of both the major Char Dham of India and the Chota Char Dham of Uttarakhand.
                    </p>
                    <p style="color: var(--text-muted); line-height: 1.8; font-size: 1.05rem;">
                        <strong>Spiritual Significance:</strong> According to legends, Lord Vishnu meditated here for thousands of years under a Badri (berry) tree to atone for humanity. His consort Goddess Lakshmi took the form of the tree to shelter him. It is believed that a visit to Badrinath guarantees Moksha (ultimate liberation), fulfilling the life purpose of a devout Hindu.
                    </p>
                </div>
            </div>
            
            <!-- Mobile Responsive Fix -->
            <style>
                @media (max-width: 768px) {
                    .premium-packages-section > .container > div {
                        grid-template-columns: 1fr !important;
                        gap: 30px !important;
                        padding: 20px !important;
                    }
                }
            </style>

        </div>
    </section>
    </section>
<footer id="contact" class="footer">
        <div class="footer-grid">
            <div class="footer-brand">
                <a href="/" class="logo">
                    <img src="assets/logo.png" alt="Triloki Tours & Travels Logo">
                </a>
                <p>Your trusted partner for premium spiritual journeys and luxury pilgrimage experiences across India.</p>
                <div class="social-links">
                    <a href="#"><i class="fa-brands fa-facebook-f"></i></a>
                    <a href="#"><i class="fa-brands fa-instagram"></i></a>
                    <a href="#"><i class="fa-brands fa-x-twitter"></i></a>
                    <a href="#"><i class="fa-brands fa-youtube"></i></a>
                </div>
            </div>
            <div class="footer-links">
                <h3>Quick Links</h3>
                <ul>
                    <li><a href="/">Home</a></li>
                    <li><a href="/#mixed-journeys">Char Dham Packages</a></li>
                    <li><a href="/#premium-heli-packages">Heli Tours</a></li>
                    <li><a href="/about">About Us</a></li>
                </ul>
            </div>
            <div class="footer-contact">
                <h3>Contact Information</h3>
                <ul>
                    <li><i class="fa-solid fa-phone"></i> <%= settings.phone %> | +91 9193336211</li>
                    <li><i class="fa-solid fa-envelope"></i> <%= settings.email %></li>
                    <li><i class="fa-solid fa-location-dot"></i> <%= settings.location %></li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            <p class="disclaimer">Disclaimer: We are tour integrators. Helicopter services are subject to weather conditions and DGCA guidelines.</p>
            <p>&copy; 2026 Triloki hospitality. All rights reserved.</p>
        </div>
    </footer>

    <!-- Inquiry Modal -->
    <div class="modal" id="inquiryModal">
        <div class="modal-content">
            <span class="close-modal" onclick="closeModal()">&times;</span>
            <h2>Request a Quote</h2>
            <p>Fill out your details and our spiritual journey expert will contact you shortly.</p>
            <form class="inquiry-form" onsubmit="event.preventDefault(); closeModal(); alert('Thank you! We will contact you soon.');">
                <input type="text" placeholder="Full Name" required>
                <input type="tel" placeholder="Phone Number" required>
                <input type="email" placeholder="Email Address">
                <select>
                    <option value="">Select Package</option>
                    <option value="dodham">Do Dham Yatra (Heli)</option>
                    <option value="chardham-road">Char Dham Premium (Road)</option>
                    <option value="chardham-heli">Complete Char Dham (Heli)</option>
                    <option value="ekdham">Ek Dham Yatra (Road)</option>
                </select>
                <button type="submit" class="cta-btn primary-btn submit-btn">Submit Request</button>
            </form>
        </div>
    </div>

    </main>
    <script src="script.js"></script>
</body>
</html>
